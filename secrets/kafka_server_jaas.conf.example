// KafkaServer — authenticates all inbound client connections.
// username/password = the broker's own identity for inter-broker and controller auth.
// user_<name> = password for that SASL/PLAIN client identity.
//
// IMPORTANT: KAFKA_ADMIN_PASSWORD and KAFKA_SASL_PASSWORD in .env must match
// user_admin and user_harmonicmesh here respectively.
KafkaServer {
   org.apache.kafka.common.security.plain.PlainLoginModule required
   serviceName="kafka"
   username="admin"
   password="<KAFKA_ADMIN_PASSWORD>"
   user_admin="<KAFKA_ADMIN_PASSWORD>"
   user_harmonicmesh="<KAFKA_SASL_PASSWORD>";
};
