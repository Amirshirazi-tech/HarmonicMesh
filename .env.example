# ── Kafka SASL credentials ────────────────────────────────────────────────────
# KAFKA_SASL_USERNAME is the service account used by all HarmonicMesh clients
# (Kafka UI, simulators, Flink jobs, agent). Must match user_harmonicmesh entry
# in secrets/kafka_server_jaas.conf.
KAFKA_SASL_USERNAME=harmonicmesh
KAFKA_SASL_PASSWORD=<your-kafka-service-password>

# Broker admin password. Must match the username/password block AND user_admin
# entry in secrets/kafka_server_jaas.conf.
KAFKA_ADMIN_PASSWORD=<your-kafka-admin-password>

# ── Kafka UI web login ────────────────────────────────────────────────────────
# Login form credentials for the Kafka UI web interface (localhost:8180).
# Independent from Kafka SASL credentials.
KAFKA_UI_PASSWORD=<your-kafka-ui-password>

# ── Neo4j ─────────────────────────────────────────────────────────────────────
# Set a strong password. Default neo4j/neo4j is intentionally not accepted.
NEO4J_PASSWORD=<your-neo4j-password>

# ── Anthropic API ─────────────────────────────────────────────────────────────
# Required from Phase 5 onward (LangGraph agent + Graphiti ingestion).
ANTHROPIC_API_KEY=<your-anthropic-api-key>
